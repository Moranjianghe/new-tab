{
  "name": "new tab",
  "description": "A new tab page for Firefox",
  "version": "0.2025.5.8",
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "new-tab@example.com",
      "strict_min_version": "121.0"
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "New Tab"
  }
}
