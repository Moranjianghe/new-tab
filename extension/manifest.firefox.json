{
  "name": "new tab",
  "description": "A new tab page for Firefox",
  "version": "0.2026.4.21",
  "manifest_version": 3,
  "browser_specific_settings": {
    "gecko": {
      "id": "new-tab@example.com",
      "strict_min_version": "109.0"
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "tabs",
    "history",
    "bookmarks"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "New Tab"
  }
}
